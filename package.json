    "dev": "vite",
    "build": "vite build && node -e \"import('esbuild').then(({build})=>build({entryPoints:['src/server/entry.ts'],bundle:true,platform:'node',format:'esm',outfile:'dist/server.bundle.mjs',allowOverwrite:true,external:['node:*','fsevents','html-to-image','@napi-rs/canvas'],define:{'import.meta.env.PROD':'true','import.meta.env.DEV':'false','import.meta.env.SSR':'true','import.meta.env.MODE':'\\\"production\\\"'},tsconfig:'tsconfig.json',banner:{js:'import{createRequire}from\\\"module\\\";const require=createRequire(import.meta.url);if(typeof globalThis.DOMMatrix===\\\"undefined\\\"){class _DM{constructor(){this.a=1;this.b=0;this.c=0;this.d=1;this.e=0;this.f=0;}multiply(){return this;}inverse(){return this;}translate(){return this;}scale(){return this;}rotate(){return this;}static fromMatrix(){return new _DM();}}globalThis.DOMMatrix=_DM;}if(typeof globalThis.ImageData===\\\"undefined\\\"){globalThis.ImageData=class{constructor(w,h){this.width=w;this.height=h;this.data=new Uint8ClampedArray(w*h*4);}}}if(typeof globalThis.Path2D===\\\"undefined\\\"){globalThis.Path2D=class{}}'}}).then(()=>console.log('Bundle complete')))\"",
    "build:vite": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "clean": "rm -rf dist node_modules/.vite",
    "reset": "npm run clean && npm install",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
